name: 生活经验库
description: 生活经验、风水、自律、戒抖音等生活感悟

filters:
  and:
    - file.inFolder("30 - 笔记和灵感/生活经验")
    - 'file.ext == "md"'
    - 'file.name != "base"'

properties:
  title:
    displayName: 标题
  tags:
    displayName: 标签

formulas:
  tags_str: 'if(tags, tags.join(", "), "")'

views:
  - type: cards
    name: 生活经验卡片
    order:
      - title
      - formula.tags_str

  - type: table
    name: 表格视图
    order:
      - file.name
      - title
      - formula.tags_str
