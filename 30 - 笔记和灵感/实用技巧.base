name: 实用技巧库
description: 生活和职场中的实用技巧、经验总结

filters:
  and:
    - file.inFolder("30 - 笔记和灵感/实用技巧")
    - 'file.ext == "md"'
    - 'file.name != "base"'

properties:
  title:
    displayName: 标题
  tags:
    displayName: 标签

formulas:
  tags_str: 'if(tags, tags.join(", "), "")'

views:
  - type: cards
    name: 技巧卡片
    order:
      - title
      - formula.tags_str

  - type: table
    name: 表格视图
    order:
      - file.name
      - title
      - formula.tags_str
