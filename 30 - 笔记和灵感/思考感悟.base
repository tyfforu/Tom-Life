name: 思考感悟库
description: 人生感悟、爱情观、自我探索

filters:
  and:
    - file.inFolder("30 - 笔记和灵感/思考感悟")
    - 'file.ext == "md"'
    - 'file.name != "base"'
    - 'file.name != "鲁豫对话文琪"'  # 空文件

properties:
  title:
    displayName: 标题
  tags:
    displayName: 标签

formulas:
  tags_str: 'if(tags, tags.join(", "), "")'

views:
  - type: cards
    name: 感悟卡片
    order:
      - title
      - formula.tags_str

  - type: table
    name: 表格视图
    order:
      - file.name
      - title
      - formula.tags_str
